{
  "name": "sound-map",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx biome check . && npm test"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^8.2.2",
    "jsdom": "^24.0.0",
    "simple-git-hooks": "^2.13.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
